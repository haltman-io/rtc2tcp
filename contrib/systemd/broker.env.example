# /etc/rtc2tcp/broker.env
#
# Configuration for the rtc2tcp-broker systemd service. Every value is
# passed through to the broker binary as a flag by the unit file; see
# `rtc2tcp-broker --help` for the authoritative flag reference.

# Address:port the broker listens on. When behind a reverse proxy that
# lives on the same host, bind loopback-only.
RTC2TCP_BROKER_LISTEN=127.0.0.1:8080

# Comma-separated list of IPs or CIDRs whose forwarded-for headers
# should be honoured. Leave empty to disable forwarded-for parsing
# entirely (the safe default for direct internet exposure).
#
# Examples:
#   Local reverse proxy (Caddy, nginx, cloudflared): 127.0.0.1,::1
#   Upstream LB on a private VPC:                    10.0.0.0/8
RTC2TCP_BROKER_TRUSTED_PROXIES=127.0.0.1,::1

# Header consulted for the real client IP when the immediate peer is a
# trusted proxy. Typical values: X-Forwarded-For, X-Real-IP,
# CF-Connecting-IP.
RTC2TCP_BROKER_TRUSTED_PROXY_HEADER=X-Forwarded-For

# Per-client-IP upgrade rate (requests / minute).
RTC2TCP_BROKER_RATE_PER_MIN=30

# Per-client-IP burst size for short spikes.
RTC2TCP_BROKER_RATE_BURST=10
